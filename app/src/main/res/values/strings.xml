    <!-- Mathematics Foundation Answer's Explanation  -->
    <string-array name="math_foundation_explanations">
        <!-- Explanation_1 -->
        <item>12 + 7 = 19. Simple addition.</item>

        <!-- Explanation_2 -->
        <item>25 - 9 = 16. Simple subtraction.</item>

        <!-- Explanation_3 -->
        <item>6 × 8 = 48. Multiplication table.</item>

        <!-- Explanation_4 -->
        <item>48 ÷ 6 = 8. Division.</item>

        <!-- Explanation_5 -->
        <item>1/2 + 1/4 = 2/4 + 1/4 = 3/4. Common denominator.</item>

        <!-- Explanation_6 -->
        <item>3/4 = 75%. Multiply numerator by 100 divided by denominator.</item>

        <!-- Explanation_7 -->
        <item>20% of 80 = (20/100) × 80 = 16.</item>

        <!-- Explanation_8 -->
        <item>4.67 rounds up to 5 since .67 is above .5.</item>

        <!-- Explanation_9 -->
        <item>2³ = 2 × 2 × 2 = 8.</item>

        <!-- Explanation_10 -->
        <item>Multiples of 4: 4,8,12. Multiples of 6: 6,12. LCM = 12.</item>
    </string-array>


